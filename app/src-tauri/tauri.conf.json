{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-v2-nightly-schema/main/schema.json",
  "productName": "KhinsiderHelper",
  "version": "1.0.0",
  "identifier": "com.khinsiderhelper.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "khinsider helper",
        "width": 900,
        "height": 640,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
